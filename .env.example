# Grok Voice is active by default. Set REALTIME_PROVIDER=openai to switch back.
REALTIME_PROVIDER=xai
XAI_API_KEY=xai-replace-me
XAI_REALTIME_MODEL=grok-voice-latest
XAI_VOICE=eve
XAI_OUTPUT_GAIN=2.0
XAI_VAD_THRESHOLD=0.85
XAI_VAD_PREFIX_PADDING_MS=333
XAI_VAD_SILENCE_DURATION_MS=900
# Optional generic prompt override. Leave empty to use Rita Crosswire.
XAI_INSTRUCTIONS=
# Optional greeting spoken after the bot joins. Leave empty for a silent join.
XAI_GREETING=

# Optional GPT Realtime fallback configuration.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
OPENAI_VOICE=marin

# Create a dedicated SIP account for the bot. Do not reuse a phone's extension.
SIP_SERVER=10.13.37.10
SIP_PORT=5060
SIP_USERNAME=199
SIP_PASSWORD=replace-with-the-bot-extension-secret
SIP_PARTYLINE=*99

# Usually auto-detected. Set this explicitly if the SDP advertises the wrong IP.
SIP_LOCAL_IP=
# Use a different local port when the bridge runs on the PBX itself.
SIP_LOCAL_PORT=5062
SIP_RTP_PORT_LOW=40000
SIP_RTP_PORT_HIGH=40100

SIP_REGISTER_TIMEOUT=15
SIP_ANSWER_TIMEOUT=30
RECONNECT_SECONDS=5
LOG_LEVEL=INFO

# The outgoing party-line bot uses 8081 so it can run beside spooky-llm.
RECORD_CALLS=true
RECORDINGS_DIR=recordings
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8081
