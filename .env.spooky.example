# Grok Voice is active by default. Set REALTIME_PROVIDER=openai to switch back.
REALTIME_PROVIDER=xai
XAI_API_KEY=xai-replace-me
XAI_REALTIME_MODEL=grok-voice-latest
SPOOKY_XAI_VOICE=eve
XAI_OUTPUT_GAIN=2.0
XAI_VAD_THRESHOLD=0.85
XAI_VAD_PREFIX_PADDING_MS=333
XAI_VAD_SILENCE_DURATION_MS=900

# Optional GPT Realtime fallback configuration.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1
SPOOKY_OPENAI_VOICE=cedar

# Provision this as a dedicated PJSIP endpoint on Asterisk.
SIP_SERVER=10.13.37.10
SIP_PORT=5060
SIP_TRANSPORT=tcp
SIP_USERNAME=666
SIP_PASSWORD=replace-with-extension-666-secret

# Separate local SIP/RTP ports allow both bot versions to run together.
SIP_LOCAL_IP=
SIP_LOCAL_PORT=5066
SIP_RTP_PORT_LOW=41000
SIP_RTP_PORT_HIGH=41100
MAX_CONCURRENT_CALLS=4

SIP_REGISTER_TIMEOUT=15
RECONNECT_SECONDS=5
LOG_LEVEL=INFO

# Record calls and expose the booth dashboard on the LAN.
RECORD_CALLS=true
RECORDINGS_DIR=recordings
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

# Optional persona overrides. The built-in defaults are already configured.
# SPOOKY_REALTIME_INSTRUCTIONS=
# SPOOKY_REALTIME_GREETING=
